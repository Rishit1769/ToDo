# =========================
# Core Runtime
# =========================
TZ=UTC
FRONTEND_PORT=3000
BACKEND_PORT=5000

# =========================
# Domain and CORS
# =========================
APP_DOMAIN=yourdomain.com
API_DOMAIN=api.yourdomain.com
CORS_ORIGIN=https://yourdomain.com

# Frontend API endpoint used at runtime by frontend container.
FRONTEND_API_BASE_URL=https://api.yourdomain.com

# Build-time fallback for CRA bundles (runtime config still overrides this).
REACT_APP_API_BASE_URL=https://api.yourdomain.com

# =========================
# MySQL
# =========================
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=todo_app
DB_USER=root
DB_PASSWORD=change_me_root_password
DB_NAME=todo_app
DB_PORT=3306
DB_CONNECTION_LIMIT=10

# =========================
# Backend Security
# =========================
JWT_SECRET=change_me_to_a_long_random_secret_value
